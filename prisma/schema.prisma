generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TAX_PROFESSIONAL
  CLIENT
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  FIRM
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum AnalysisType {
  TAT
  VAT
  PAYE
  EFRIS
  INCOME_TAX
  GENERAL
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String
  fullName        String
  phone           String?
  organization    String?
  role            UserRole      @default(TAX_PROFESSIONAL)
  plan            SubscriptionPlan @default(STARTER)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  documents       Document[]
  analyses        Analysis[]
  reports         Report[]
}

model Document {
  id              String          @id @default(uuid())
  userId          String
  filename        String
  fileType        String
  fileSize        Int
  storageUrl      String
  status          DocumentStatus @default(PROCESSING)

  uploadedAt      DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])
  analyses        Analysis[]
}

model Analysis {
  id              String       @id @default(uuid())
  userId          String
  documentId      String?

  title           String
  summary         String       @db.Text
  recommendation  String       @db.Text

  riskLevel       RiskLevel
  analysisType    AnalysisType

  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])
  document        Document? @relation(fields: [documentId], references: [id])

  issues          AnalysisIssue[]
  reports         Report[]
}

model AnalysisIssue {
  id            String @id @default(uuid())
  analysisId    String

  issue         String
  severity      RiskLevel

  analysis      Analysis @relation(fields: [analysisId], references: [id])
}

model Report {
  id            String @id @default(uuid())

  userId        String
  analysisId    String

  title         String
  clientName    String
  reportUrl     String?

  createdAt     DateTime @default(now())

  user          User @relation(fields: [userId], references: [id])
  analysis      Analysis @relation(fields: [analysisId], references: [id])
}

model TatCase {
  id              String @id @default(uuid())

  caseNumber      String
  caseName        String
  year            Int

  taxType         String

  outcome         String

  summary         String @db.Text
  fullText        String @db.Text

  createdAt       DateTime @default(now())

  tags            TatCaseTag[]
}

model Tag {
  id          String @id @default(uuid())
  name        String @unique

  cases       TatCaseTag[]
}

model TatCaseTag {
  caseId      String
  tagId       String

  case        TatCase @relation(fields: [caseId], references: [id])
  tag         Tag @relation(fields: [tagId], references: [id])

  @@id([caseId, tagId])
}
